@page "/documents"
@rendermode InteractiveServer
@inject ILogger<Documents> Logger
@inject IToastService ToastService

<PageTitle>Documents</PageTitle>

<FluentLayout>
    <FluentHeader>Documents</FluentHeader>

    <FluentStack Orientation="Orientation.Vertical">
        <FluentToolbar>
            <FluentSelect Items="@items"
                          OptionText="@(o => o.Text)"
                          OptionValue="@(o => o.Value)"
                          TOption="Option<string>"
                          ValueChanged="@OnValueChanged" />

            <FluentCheckbox Value="@includeAll" ValueChanged="@((e) => OnInCludeAllChange(e))">All Members</FluentCheckbox>
        </FluentToolbar>

        @if (document != null)
        {
            <FluentCard>
                <FluentLabel>Type: @document.Type.Name</FluentLabel>

                <FluentDataGrid Items="@document?.Items.AsQueryable()" TGridItem="CSDocumentItem" MultiLine="true">
                    <PropertyColumn Property="@(c => c.Name)" />
                    <PropertyColumn Property="@(c => c.MemberType)" Title="Member Type" />
                    <PropertyColumn Property="@(c => c.DisplayName)" Title="Display Name" />
                    <PropertyColumn Property="@(c => c.Comment.Summary)" />
                    <PropertyColumn Property="@(c => c.Comment.Remarks)" />
                    <PropertyColumn Property="@(c => c.Comment.Returns)" />
                </FluentDataGrid>
            </FluentCard>
        }
    </FluentStack>
</FluentLayout>

@code {
    private List<Option<string>> items = [];
    private ICSDocument? document;
    private List<ICSDocument> documents = [];
    private bool includeAll;

    protected override void OnInitialized()
    {
        BuildDocuments(nameof(MyClass));
    }

    private void BuildDocuments(string name)
    {
        try
        {
            var cdReader = new CSDocumentReader("Sandbox.XmlLib");
            cdReader.LoadXml(logger: Logger);

            documents = new List<ICSDocument>
            {
                cdReader.CreateDocument<MyClass>(includeAll),
                cdReader.CreateDocument<MyClass<MyClass>>(includeAll),
                cdReader.CreateDocument<MyEnum>(includeAll),
                cdReader.CreateDocument<MyModelClassBase>(includeAll),
                cdReader.CreateDocument<MyModelClass>(includeAll),
                cdReader.CreateDocument<MyModelClass<MyClass>>(includeAll),
                cdReader.CreateDocument<MyModelEnum>(includeAll)
            };

            var options = new List<Option<string>>();
            foreach (var item in documents)
            {
                options.Add(new Option<string>() { Text = item.Type.Name, Value = item.Type.Name });
            }
            items.Clear();
            items.AddRange(options);

            OnValueChanged(name);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, null);
            ToastService.ShowError(ex.Message);
        }
        finally
        {
            StateHasChanged();
        }
    }

    private void OnInCludeAllChange(bool value)
    {
        includeAll = value;
        BuildDocuments(document?.Type.Name ?? nameof(MyClass));
    }

    private void OnValueChanged(string? value)
    {
        document = documents.FirstOrDefault(e => e.Type.Name == value);
    }
}
